# GEMINI_API_KEY: optional. Without it, the board narration falls back to a
# deterministic canned response automatically — the app keeps working either way.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# LLM_PROVIDER: set to "fallback" to force the deterministic narrator even
# when GEMINI_API_KEY is set (useful for offline dev / tests).
LLM_PROVIDER=""

# NODE_ENV: "production" makes the FastAPI process also serve the built
# frontend (dist/) on the same port. Leave unset in dev — Vite serves the
# frontend on :3000 and proxies /api to FastAPI on :8000.
NODE_ENV=""
