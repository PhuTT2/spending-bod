# ─── GreenNode MaaS (OpenAI-compatible) ────────────────────────────────────────
# Base URL for GreenNode AI Platform
LLM_BASE_URL="https://maas-llm-aiplatform-hcm.api.vngcloud.vn/v1"

# Shared API key for all GreenNode MaaS calls
LLM_API_KEY="<your-greennode-api-key>"

# Provider selector: "openai" → use OpenAI-compatible endpoint above
# "fallback" → deterministic canned responses (offline/test mode)
LLM_PROVIDER="openai"

# ─── Per-task model routing ─────────────────────────────────────────────────────
# Model used for board narration / debate (Gemma recommended — creative, expressive)
NARRATION_MODEL="google/gemma-4-31b-it"

# Model used for AI follow-up questions and advice (DeepSeek recommended — analytical)
FOLLOWUP_MODEL="deepseek/deepseek-v4-pro"

# Override base URL / key for the follow-up model if it's on a different endpoint
# Leave unset to reuse LLM_BASE_URL and LLM_API_KEY
# FOLLOWUP_BASE_URL=""
# FOLLOWUP_API_KEY=""

# ─── OpenAI (for GPT Image 1 verdict card generation) ──────────────────────────
OPENAI_API_KEY="sk-..."
IMAGE_MODEL="gpt-image-1"

# ─── Gemini (legacy, optional) ──────────────────────────────────────────────────
# GEMINI_API_KEY="<your-gemini-key>"

# ─── Runtime ────────────────────────────────────────────────────────────────────
# "production" → FastAPI also serves the built frontend on the same port.
# Leave unset in dev — Vite serves on :3000, proxies /api to FastAPI on :8000.
NODE_ENV=""
