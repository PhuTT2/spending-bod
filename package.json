{
  "name": "spending-bod",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n WEB,API -c cyan,magenta \"vite\" \"npm:dev:api\"",
    "dev:api": "uvicorn app.main:app --reload --port 8000 --app-dir backend",
    "build": "vite build",
    "start": "cross-env NODE_ENV=production uvicorn app.main:app --port 3000 --app-dir backend",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "lucide-react": "^0.546.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "vite": "^6.2.3",
    "motion": "^12.23.24"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2"
  }
}
